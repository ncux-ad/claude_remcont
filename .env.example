# Claude Code ↔ Telegram Bridge — environment variables
# Copy to ~/.env.claude-tg and fill in real values

# Telegram bot token from @BotFather (required)
TG_BOT_TOKEN=your_bot_token_here

# Comma-separated list of allowed Telegram chat IDs (required)
# Get your chat ID by messaging @userinfobot
TG_ALLOWED_CHATS=123456789

# Absolute path to the project directory Claude Code will work in (required)
CLAUDE_PROJECT_DIR=/home/user/my_project

# Claude CLI binary name or full path (default: claude)
CLAUDE_BIN=claude

# Task timeout in seconds; 0 = no timeout (warning: tasks can hang forever)
CLAUDE_TASK_TIMEOUT=300

# Global max pending+running tasks across all chats (default: 50)
CLAUDE_MAX_QUEUE_SIZE=50

# Max pending+running tasks per individual chat (default: 5)
CLAUDE_PER_CHAT_QUEUE_LIMIT=5

# Circuit breaker: open after this many consecutive Claude failures per chat (default: 3)
CLAUDE_CB_THRESHOLD=3

# Circuit breaker: seconds to block a chat after opening (default: 300)
CLAUDE_CB_COOLDOWN=300

# Heartbeat max age in seconds before healthcheck alerts (default: 120)
CLAUDE_HEARTBEAT_MAX_AGE=120

# Auto-delete done/error tasks older than N days (default: 7)
CLAUDE_QUEUE_CLEANUP_DAYS=7

# Auto-delete sessions unused for N days (default: 30)
CLAUDE_SESSION_CLEANUP_DAYS=30
